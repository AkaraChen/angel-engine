{
  "name": "@angel-engine/agent-session",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:debug": "tsup && tsc -p tsconfig.build.json",
    "lint": "oxlint --type-aware src",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "3.22.0"
  },
  "devDependencies": {
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
