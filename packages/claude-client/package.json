{
  "name": "@angel-engine/claude-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js",
      "require": "./dist/adapter.cjs"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "require": "./dist/context.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "build:debug": "tsup && tsc -p tsconfig.build.json",
    "lint": "oxlint --type-aware src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@angel-engine/js-client": "workspace:*",
    "@sindresorhus/is": "^8.1.0",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@angel-engine/client-napi": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "@types/mime-types": "^3.0.1",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@angel-engine/client-napi": "0.1.0"
  }
}
