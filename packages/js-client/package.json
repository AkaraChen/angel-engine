{
  "name": "@angel-engine/js-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assistant-ui": {
      "types": "./dist/assistant-ui.d.ts",
      "default": "./dist/assistant-ui.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "default": "./dist/mock.js"
    },
    "./projection": {
      "types": "./dist/projection.d.ts",
      "default": "./dist/projection.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./utils/attachments": {
      "types": "./dist/utils/attachments.d.ts",
      "default": "./dist/utils/attachments.js"
    },
    "./utils/client-update": {
      "types": "./dist/utils/client-update.d.ts",
      "default": "./dist/utils/client-update.js"
    },
    "./utils/core": {
      "types": "./dist/utils/core.d.ts",
      "default": "./dist/utils/core.js"
    },
    "./utils/elicitations": {
      "types": "./dist/utils/elicitations.d.ts",
      "default": "./dist/utils/elicitations.js"
    },
    "./utils/errors": {
      "types": "./dist/utils/errors.d.ts",
      "default": "./dist/utils/errors.js"
    },
    "./utils/media": {
      "types": "./dist/utils/media.d.ts",
      "default": "./dist/utils/media.js"
    },
    "./utils/messages": {
      "types": "./dist/utils/messages.d.ts",
      "default": "./dist/utils/messages.js"
    },
    "./utils/plans": {
      "types": "./dist/utils/plans.d.ts",
      "default": "./dist/utils/plans.js"
    },
    "./utils/tools": {
      "types": "./dist/utils/tools.d.ts",
      "default": "./dist/utils/tools.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:debug": "tsc -p tsconfig.build.json",
    "dev": "vite --host 127.0.0.1 --config playground/vite.config.ts",
    "lint": "oxlint --type-aware src",
    "playground": "vite --host 127.0.0.1 --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@angel-engine/client-napi": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "@assistant-ui/react": "^0.14.26",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@angel-engine/client-napi": "0.1.0",
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "@assistant-ui/react": "^0.12.28",
    "react": "^19.2.6"
  },
  "peerDependenciesMeta": {
    "@assistant-ui/react": {
      "optional": true
    },
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@sindresorhus/is": "^8.1.0",
    "arktype": "^2.2.2"
  }
}
