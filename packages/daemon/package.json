{
  "name": "@angel-engine/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "angel-engine-daemon": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:debug": "tsup",
    "dev": "tsx src/main.ts --data-dir .data --print-handshake",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "hono": "4.12.25"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@types/node": "^24.10.1",
    "eslint": "^10.6.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
