{
  "name": "@angel-engine/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "angel-engine-daemon": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:debug": "tsup",
    "dev": "tsx src/main.ts --data-dir .data --print-handshake",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angel-engine/client-napi": "workspace:*",
    "@angel-engine/daemon-api": "workspace:*",
    "@angel-engine/claude-client": "workspace:*",
    "@angel-engine/js-client": "workspace:*",
    "@angel-engine/pi-client": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@sindresorhus/is": "^8.1.0",
    "arktype": "^2.2.2",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "hono": "4.12.25",
    "mime-types": "^3.0.2",
    "node-pty": "1.1.0",
    "which": "^7.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@types/node": "^24.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "@types/which": "^3.0.4",
    "eslint": "^10.6.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
