{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".vite/**",
    "dist/**",
    "out/**",
    "src/renderer/components/ai-elements/**",
    "src/renderer/components/ui/**"
  ],
  "plugins": ["typescript", "unicorn", "oxc", "import", "react"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "import/no-duplicates": "error",
    "typescript/await-thenable": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/no-unsafe-argument": "warn",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-unsafe-return": "warn",
    "typescript/return-await": "warn",
    "typescript/switch-exhaustiveness-check": "error",
    "typescript/unbound-method": "warn"
  },
  "overrides": [
    {
      "files": ["src/**/*.{ts,tsx,mts}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["../main/*", "../../main/*", "../../../main/*"],
                "message": "Renderer/preload code must not import main-process modules."
              },
              {
                "group": ["@renderer/*", "../renderer/*", "../../renderer/*"],
                "message": "Main/preload/shared code must not import renderer modules."
              }
            ]
          }
        ]
      }
    }
  ]
}
