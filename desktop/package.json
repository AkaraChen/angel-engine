    "@types/which": "^3.0.4",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "oxlint": "^1.73.0",
