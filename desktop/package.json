{
  "name": "desktop",
  "productName": "Angel Engine",
  "version": "0.0.4-beta32",
  "private": true,
  "description": "Desktop shell for Angel Engine.",
  "author": {
    "name": "akarachen",
    "email": "akarachen@outlook.com"
  },
  "license": "MIT",
  "keywords": [],
  "main": ".vite/build/main.js",
  "scripts": {
    "runtime:build": "turbo run build --filter @angel-engine/client-napi --filter @angel-engine/js-client --filter @angel-engine/claude-client --filter @angel-engine/pi-client --filter @angel-engine/daemon-api --filter @angel-engine/daemon --filter mobile",
    "runtime:build:debug": "turbo run build:debug --filter @angel-engine/client-napi --filter @angel-engine/js-client --filter @angel-engine/claude-client --filter @angel-engine/pi-client --filter @angel-engine/daemon-api --filter @angel-engine/daemon",
    "start": "bun run runtime:build:debug && electron-forge start",
    "package": "bun run runtime:build && bun run rebuild:native && node scripts/package-app.cjs",
    "make": "bun run package && node scripts/build-prepackaged.cjs --publish never",
    "publish": "bun run package && node scripts/build-prepackaged.cjs --publish always",
    "lint": "oxlint --type-aware .",
    "db:generate": "drizzle-kit generate",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angel-engine/claude-client": "workspace:*",
    "@angel-engine/client-napi": "workspace:*",
    "@angel-engine/daemon": "workspace:*",
    "@angel-engine/daemon-api": "workspace:*",
    "@angel-engine/js-client": "workspace:*",
    "@angel-engine/pi-client": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "0.3.198",
    "@assistant-ui/core": "0.2.20",
    "@assistant-ui/react": "^0.14.26",
    "@assistant-ui/react-streamdown": "^0.3.5",
    "@chenglou/pretext": "^0.0.8",
    "@egoist/tipc": "^0.3.2",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/playwrite-de-la": "^5.2.7",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@monaco-editor/react": "^4.7.0",
